# =============================================================================
# TURON Platform — Environment Variables Reference
# Copy this file to .env on AWS and fill in real values there.
# Never commit real credentials, tokens, database URLs, or production secrets.
# =============================================================================

# ── Database: Supabase Postgres ───────────────────────────────────────────────
# Runtime Prisma URL. Prefer Supabase pooler for the API process.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=15&connect_timeout=60&sslmode=require"

# Direct database URL for migrations. Prefer direct Supabase host.
DIRECT_URL="postgresql://USER:PASSWORD@DB_HOST:5432/postgres?sslmode=require"

# ── Telegram Bot ──────────────────────────────────────────────────────────────
BOT_TOKEN="YOUR_BOTFATHER_TOKEN"
RUN_TELEGRAM_BOT=true

# ── Auth & Security ───────────────────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# ── AWS Backend Server ────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3000
API_HOST="0.0.0.0"

# Public HTTPS API domain served by Nginx/Caddy/Certbot on AWS.
API_PUBLIC_URL="https://turonkafe.duckdns.org"

# ── Frontend / Telegram Mini App ──────────────────────────────────────────────
# Vercel Mini App URL. This is what Telegram buttons open.
WEB_APP_URL="https://turon-miniapp.vercel.app"

# Backend CORS allow-list. Include your Vercel production domain.
CORS_ORIGIN="https://turon-miniapp.vercel.app"

# Vite build-time frontend API URL. In production this must be the AWS HTTPS API.
VITE_API_URL="https://turonkafe.duckdns.org"
VITE_TELEGRAM_BOT_NAME="turonkafebot"

# ── Admin Telegram Group ──────────────────────────────────────────────────────
ADMIN_CHAT_ID="-1001234567890"
ADMIN_IDS="123456789,987654321"

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
# Required if courier assignment queue must run through BullMQ.
# Use Upstash/Redis Cloud/AWS ElastiCache reachable from the backend server.
REDIS_URL="redis://USER:PASSWORD@HOST:6379"

# ── Yandex Maps ───────────────────────────────────────────────────────────────
YANDEX_MAP_API_KEY="YOUR_SERVER_SIDE_KEY"
YANDEX_GEOCODER_API_KEY="YOUR_SERVER_SIDE_KEY"
YANDEX_GEOSUGGEST_API_KEY="YOUR_SERVER_SIDE_KEY"
YANDEX_ROUTER_API_KEY="YOUR_SERVER_SIDE_KEY"
YANDEX_DISTANCE_MATRIX_API_KEY="YOUR_SERVER_SIDE_KEY"

# Browser-facing map settings for Vercel builds.
VITE_MAPS_PROVIDER="yandex"
VITE_MAP_API_KEY="YOUR_BROWSER_MAP_KEY"
VITE_MAP_LANGUAGE="uz_UZ"

# ── Supabase Storage, if frontend uses direct public bucket URLs ───────────────
VITE_SUPABASE_URL="https://PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
