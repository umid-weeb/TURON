# =============================================================================
# TURON Platform — Environment Variables Reference
# Copy this file to .env and fill in your real values.
# NEVER commit .env with real credentials to git.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase pgBouncer pooler URL (used by Prisma at runtime)
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=15&connect_timeout=60&sslmode=require"

# Direct connection for migrations (optional but recommended)
# DIRECT_URL="postgresql://postgres:DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Token from @BotFather
BOT_TOKEN="1234567890:YOUR_BOT_TOKEN_FROM_BOTFATHER"

# Set to true to run bot inside the API process
RUN_TELEGRAM_BOT=true

# ── Auth & Security ───────────────────────────────────────────────────────────
# Use a long random string — at least 32 characters
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3000
API_HOST="0.0.0.0"

# ── URLs ──────────────────────────────────────────────────────────────────────
# Where the Mini App is hosted (no trailing slash)
WEB_APP_URL="https://your-miniapp.vercel.app"
CORS_ORIGIN="https://your-miniapp.vercel.app"

# ── Admin ─────────────────────────────────────────────────────────────────────
# Telegram group chat ID for admin notifications (e.g. -1001234567890)
ADMIN_CHAT_ID="-1001234567890"

# Comma-separated list of admin Telegram user IDs
ADMIN_IDS="123456789,987654321"

# ── Yandex Maps (backend services) ───────────────────────────────────────────
# Used by geocoding, routing, and distance matrix APIs server-side
YANDEX_MAP_API_KEY="your-yandex-map-api-key"
YANDEX_GEOCODER_API_KEY="your-yandex-geocoder-api-key"
YANDEX_GEOSUGGEST_API_KEY="your-yandex-geosuggest-api-key"
YANDEX_ROUTER_API_KEY="your-yandex-router-api-key"
YANDEX_DISTANCE_MATRIX_API_KEY="your-yandex-distance-matrix-api-key"

# ── Frontend (Vite Mini App) ──────────────────────────────────────────────────
# Vite reads VITE_* vars from repo root (envDir: '../../' in vite.config.ts).
# For production builds, these are also in .env.production at repo root.

# Base URL of the backend API (no trailing slash)
VITE_API_URL="https://your-api-domain.com"

# Telegram bot handle (without @) — used for deep-links
VITE_TELEGRAM_BOT_NAME="YourBotName"

# Maps provider: "yandex" or "none"
VITE_MAPS_PROVIDER="yandex"

# Yandex Maps JS API key (browser-facing)
VITE_MAP_API_KEY="your-yandex-maps-api-key"

# UI language for Yandex Maps
VITE_MAP_LANGUAGE="uz_UZ"
