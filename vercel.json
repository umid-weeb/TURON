{
  "version": 2,
  "public": true,
  "buildCommand": "pnpm --filter @turon/miniapp build",
  "installCommand": "pnpm install",
  "framework": "vite",
  "devCommand": "pnpm dev:miniapp",
  "outputDirectory": "apps/miniapp/dist",
  "build": {
    "env": {
      "VITE_API_URL": "https://turonkafe.duckdns.org",
      "VITE_MAPS_PROVIDER": "yandex",
      "VITE_MAP_API_KEY": "c3e2b675-cbbf-4886-b77a-3ed4e0d4f3f8",
      "VITE_MAP_LANGUAGE": "uz_UZ"
    }
  },
  "rewrites": [
    { "source": "/customer", "destination": "/" },
    { "source": "/customer/:path*", "destination": "/" },
    { "source": "/admin", "destination": "/" },
    { "source": "/admin/:path*", "destination": "/" },
    { "source": "/courier", "destination": "/" },
    { "source": "/courier/:path*", "destination": "/" }
  ]
}
